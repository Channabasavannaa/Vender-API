node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package.json
package-lock.json
tsconfig.json

# Environment Variables
.env
.env.*
!.env.example

# Build Output
dist/
build/
coverage/

# TypeScript
*.tsbuildinfo

